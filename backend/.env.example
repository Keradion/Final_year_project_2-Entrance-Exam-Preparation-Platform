# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lms?retryWrites=true&w=majority

# Redis Configuration (BullMQ queues, JWT blacklist, rate limits, HTTP read-through cache)
REDIS_URL=redis://localhost:6379
# REDIS_ENABLED=false
# APP_CACHE_PREFIX=lms
# CACHE_TTL_CONTENT_SEC=600
# CACHE_TTL_PROGRESS_SEC=45

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Configuration (for future use)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_password
EMAIL_FROM=your_email@gmail.com
RESET_PASSWORD_URL=http://localhost:5173

# Telegram Configuration (for FR-10)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
